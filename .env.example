# Run `npm run doctor` after editing. Per-project checklist: docs/PROJECT_PLAYBOOK.md
#
# --- Core ---
# WORKSPACE_PATH = racine « contrôle » du bot : tasks/, logs/, reports/, .devbot/
#   Défaut : ~/devbot-workspace
#   Ex. tout sous Documents/HOHOBOT :
# WORKSPACE_PATH=~/Documents/HOHOBOT
WORKSPACE_PATH=~/devbot-workspace

# When false: empty tasks/ is not filled from samples/tasks (useful for production / remote-only jobs you define yourself).
DEVBOT_SEED_SAMPLE_TASKS=true

# DEVBOT_PROJECTS_DIR = dépôts & scaffolds (/create, /projects, /dev …). Défaut : WORKSPACE_PATH/projects
#   Ex. uniquement sous Documents/HOHOSOL (séparé de HOHOBOT) :
# DEVBOT_PROJECTS_DIR=~/Documents/HOHOSOL

# When true: agent pipeline skips shell execution; create skips npm install side-effects where applicable.
DRY_RUN=true

# When true: approval gates auto-resolve (do NOT use on shared machines).
AUTO_APPROVE=false
ASSISTANT_NAME=devBOT
ASSISTANT_GREETING=devBOT ready 🚀
# Comma-separated absolute or ~/ paths allowed for desktop-side folder creation actions.
DESKTOP_ALLOWED_PATHS=~/Desktop,~/Desktop/future-projects,~/Desktop/Future Project

# OpenAI: /chat (LLM, no shell) + optional coaching in reports. Set key or /chat stays disabled.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
# Future: OpenRouter model slug when wired in.
OPENROUTER_MODEL=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# Leave empty or use 0 on first run: listener replies with your chat id (bootstrap). Set real id then restart.
TELEGRAM_CHAT_ID=
TELEGRAM_POLL_TIMEOUT=45

# --- WhatsApp ---
# Full WhatsApp jid allowed to control the bot (example: 32451015476@c.us).
# With Telegram configured too: npm run bot:bots (one terminal, same /commands).
WHATSAPP_ALLOWED_CHAT=
# Optional local auth session name under WORKSPACE_PATH/.devbot/
WHATSAPP_SESSION_NAME=devbot

# --- GitHub (optional automation) ---
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
GITHUB_DEFAULT_BRANCH=main
GITHUB_CREATE_PR=false
