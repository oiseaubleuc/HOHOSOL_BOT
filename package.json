{
  "name": "ai-dev-bot",
  "version": "0.1.0",
  "private": true,
  "description": "MVP control-plane style AI dev assistant: Laravel-first scanning, plans, gated artisan commands, Node fallback.",
  "type": "module",
  "bin": {
    "ai-dev-bot": "./dist/cli.js"
  },
  "scripts": {
    "dev": "node --import tsx/esm src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
